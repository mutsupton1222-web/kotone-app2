<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>ことねちゃんのあそびば🌸</title>
<style>
/* ═══════════════════════════════════════
   BASE
═══════════════════════════════════════ */
*{margin:0;padding:0;box-sizing:border-box;}
body{
  font-family:'Hiragino Maru Gothic Pro','BIZ UDPGothic','Segoe UI',sans-serif;
  overflow:hidden; height:100vh; width:100vw;
  user-select:none; -webkit-user-select:none;
  touch-action:manipulation; cursor:pointer;
}

/* ═══════════════════════════════════════
   TOP BANNER
═══════════════════════════════════════ */
#banner{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 16px;
  background:linear-gradient(135deg,#ff6eb4dd,#ffb347dd);
  backdrop-filter:blur(10px);
  border-bottom:3px solid rgba(255,255,255,.5);
  box-shadow:0 4px 20px rgba(255,100,150,.3);
  min-height:52px;
}
#banner-title{
  font-size:clamp(14px,4vw,22px);font-weight:900;color:#fff;
  text-shadow:0 2px 8px rgba(180,40,80,.4);letter-spacing:.06em;
}
#score-pill{
  background:rgba(255,255,255,.35);border-radius:999px;
  padding:4px 14px;font-size:clamp(16px,4vw,22px);font-weight:900;
  color:#fff;text-shadow:0 1px 4px rgba(0,0,0,.2);min-width:64px;text-align:center;
}

/* ═══════════════════════════════════════
   SCREENS  (menu / animal / vehicle)
═══════════════════════════════════════ */
.screen{
  position:fixed;inset:0;top:52px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity .4s;
}
.screen.hidden{opacity:0;pointer-events:none;}

/* ── MENU ── */
#screen-menu{
  background:linear-gradient(160deg,#fff0fa 0%,#ffe8b3 60%,#e8f8ff 100%);
  gap:28px;
}
.menu-title{
  font-size:clamp(26px,7vw,48px);font-weight:900;
  color:#ff5fa0;text-shadow:0 3px 12px rgba(255,100,160,.3);
  letter-spacing:.06em;
}
.menu-sub{font-size:clamp(14px,3.5vw,20px);color:#ff9f43;font-weight:700;}
.menu-cards{display:flex;gap:24px;flex-wrap:wrap;justify-content:center;padding:0 16px;}
.menu-card{
  width:min(42vw,180px);aspect-ratio:1;
  border-radius:28px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:10px;
  cursor:pointer;transition:transform .15s,box-shadow .15s;
  box-shadow:0 8px 32px rgba(0,0,0,.12);
  border:4px solid rgba(255,255,255,.8);
}
.menu-card:active{transform:scale(.94);}
.menu-card.pink{background:linear-gradient(145deg,#ffb3d9,#ff6eb4);}
.menu-card.blue{background:linear-gradient(145deg,#a8d8ff,#4d96ff);}
.menu-card .card-emoji{font-size:clamp(44px,12vw,70px);}
.menu-card .card-label{
  font-size:clamp(13px,3.5vw,18px);font-weight:900;color:#fff;
  text-shadow:0 2px 6px rgba(0,0,0,.25);letter-spacing:.04em;
}

/* ── GAME BACKGROUNDS ── */
#screen-animal{background:radial-gradient(ellipse at center,#ff9de2 0%,#ffb347 50%,#fff0fa 100%);}
#screen-vehicle{background:linear-gradient(180deg,#1a3a6b 0%,#2255a4 40%,#6ab4ff 100%);}

/* back button */
.back-btn{
  position:fixed;top:60px;left:12px;z-index:90;
  background:rgba(255,255,255,.35);backdrop-filter:blur(8px);
  border:2px solid rgba(255,255,255,.6);border-radius:999px;
  padding:6px 16px;font-size:16px;font-weight:900;color:#fff;
  text-shadow:0 1px 4px rgba(0,0,0,.3);cursor:pointer;
  transition:transform .12s;
}
.back-btn:active{transform:scale(.93);}

/* ═══════════════════════════════════════
   SHARED CANVAS
═══════════════════════════════════════ */
#canvas{position:fixed;inset:0;top:52px;pointer-events:none;z-index:10;}

/* ═══════════════════════════════════════
   ANIMAL GAME
═══════════════════════════════════════ */
.tap-animal{
  position:absolute;pointer-events:none;
  transform:translate(-50%,-50%) scale(0);
  animation:pop-in .4s cubic-bezier(.175,.885,.32,1.275) forwards,
            float-up 2s ease-in .3s forwards;
  line-height:1;
}
@keyframes pop-in{
  0%  {transform:translate(-50%,-50%) scale(0) rotate(-20deg);}
  60% {transform:translate(-50%,-50%) scale(1.35) rotate(10deg);}
  100%{transform:translate(-50%,-50%) scale(1) rotate(0);}
}
@keyframes float-up{
  0%  {opacity:1;transform:translate(-50%,-50%) scale(1);}
  100%{opacity:0;transform:translate(-50%,calc(-50% - 220px)) scale(.5);}
}

/* ─ BOSS (animal) ─ */
#animal-boss{
  position:fixed;left:50%;top:50%;z-index:50;
  transform:translate(-50%,-50%) scale(0);
  font-size:clamp(120px,30vw,200px);line-height:1;
  filter:drop-shadow(0 0 40px rgba(255,200,50,.8));
  transition:transform .5s cubic-bezier(.175,.885,.32,1.275);
  pointer-events:auto;cursor:pointer;
  display:none;
}
#animal-boss.show{display:block;transform:translate(-50%,-50%) scale(1);}
#animal-boss.hit{animation:boss-hit .15s ease-in-out;}
@keyframes boss-hit{0%,100%{filter:drop-shadow(0 0 40px rgba(255,200,50,.8));}
  50%{filter:brightness(2) drop-shadow(0 0 60px #fff);}}
#boss-hp{
  position:fixed;left:50%;bottom:20%;transform:translateX(-50%);
  z-index:51;display:none;align-items:center;gap:10px;
}
#boss-hp.show{display:flex;}
#boss-hp-bar-wrap{
  width:min(70vw,300px);height:22px;background:rgba(0,0,0,.3);
  border-radius:999px;overflow:hidden;border:2px solid rgba(255,255,255,.5);
}
#boss-hp-bar{height:100%;background:linear-gradient(90deg,#ff4f4f,#ff9f43);
  border-radius:999px;transition:width .2s;}
#boss-hp-label{font-size:18px;font-weight:900;color:#fff;
  text-shadow:0 2px 6px rgba(0,0,0,.4);}
#boss-event-label{
  position:fixed;top:80px;left:50%;transform:translateX(-50%);
  z-index:55;font-size:clamp(24px,7vw,40px);font-weight:900;
  color:#fff;text-shadow:0 0 20px #ff4f4f,0 4px 12px rgba(0,0,0,.4);
  display:none;animation:label-pulse 1s ease-in-out infinite;
  white-space:nowrap;pointer-events:none;
}
#boss-event-label.show{display:block;}
@keyframes label-pulse{0%,100%{transform:translateX(-50%) scale(1);}
  50%{transform:translateX(-50%) scale(1.08);}}

/* ═══════════════════════════════════════
   VEHICLE GAME
═══════════════════════════════════════ */
/* ground strip */
#road{
  position:fixed;bottom:0;left:0;right:0;height:70px;z-index:5;
  background:linear-gradient(180deg,#3a4a5a,#2a3a4a);
  border-top:4px solid #5a6a7a;
}
#road::before{
  content:'';position:absolute;top:50%;left:0;right:0;height:4px;
  background:repeating-linear-gradient(90deg,#fff 0,#fff 40px,transparent 40px,transparent 80px);
  transform:translateY(-50%);opacity:.4;
}

.vehicle{
  position:fixed;pointer-events:auto;cursor:pointer;
  transform:translateX(-50%);
  transition:filter .1s;
  z-index:20;
  font-size:60px;line-height:1;
  /* top set by JS */
}
.vehicle:active{filter:brightness(1.8);}
.vehicle.hit-flash{animation:v-hit .12s linear;}
@keyframes v-hit{0%,100%{filter:brightness(1);}50%{filter:brightness(2.2);}}

/* ─ VEHICLE BOSS ─ */
#vehicle-boss{
  position:fixed;left:50%;z-index:60;
  transform:translateX(-50%);
  font-size:clamp(130px,32vw,210px);line-height:1;
  filter:drop-shadow(0 0 50px rgba(100,200,255,.8));
  pointer-events:auto;cursor:pointer;
  display:none;
}
#vehicle-boss.show{display:block;}
#vehicle-boss.hit{animation:boss-hit .15s ease-in-out;}

#vboss-hp{
  position:fixed;left:50%;bottom:22%;transform:translateX(-50%);
  z-index:61;display:none;align-items:center;gap:10px;
}
#vboss-hp.show{display:flex;}
#vboss-hp-bar-wrap{
  width:min(70vw,300px);height:22px;background:rgba(0,0,0,.3);
  border-radius:999px;overflow:hidden;border:2px solid rgba(255,255,255,.5);
}
#vboss-hp-bar{height:100%;background:linear-gradient(90deg,#4d96ff,#00cec9);
  border-radius:999px;transition:width .2s;}
#vboss-hp-label{font-size:18px;font-weight:900;color:#fff;
  text-shadow:0 2px 6px rgba(0,0,0,.4);}
#vboss-event-label{
  position:fixed;top:80px;left:50%;transform:translateX(-50%);
  z-index:65;font-size:clamp(24px,7vw,40px);font-weight:900;
  color:#fff;text-shadow:0 0 20px #4d96ff,0 4px 12px rgba(0,0,0,.4);
  display:none;animation:label-pulse 1s ease-in-out infinite;
  white-space:nowrap;pointer-events:none;
}
#vboss-event-label.show{display:block;}

/* ═══════════════════════════════════════
   SHARED FX
═══════════════════════════════════════ */
.ripple{
  position:absolute;border-radius:50%;
  transform:translate(-50%,-50%) scale(0);
  animation:ripple-out .7s ease-out forwards;
  pointer-events:none;
}
@keyframes ripple-out{to{transform:translate(-50%,-50%) scale(8);opacity:0;}}

.star-burst{
  position:absolute;pointer-events:none;
  animation:star-fly .9s ease-out forwards;
}
@keyframes star-fly{
  0%  {opacity:1;transform:translate(-50%,-50%) scale(1.2);}
  100%{opacity:0;transform:translate(calc(-50% + var(--tx)),calc(-50% + var(--ty))) scale(0);}
}

/* combo */
#combo-display{
  position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
  font-size:clamp(20px,5.5vw,32px);font-weight:900;color:#fff;
  text-shadow:0 0 20px rgba(255,80,150,.8);z-index:80;
  opacity:0;transition:opacity .3s;white-space:nowrap;pointer-events:none;
}
#combo-display.visible{opacity:1;}

/* score pop */
.score-pop{
  position:fixed;font-size:clamp(20px,6vw,36px);font-weight:900;color:#fff;
  text-shadow:0 0 16px rgba(255,200,0,.9),0 2px 6px rgba(0,0,0,.3);
  pointer-events:none;z-index:90;
  animation:score-pop-anim .8s ease-out forwards;
}
@keyframes score-pop-anim{
  0%  {opacity:1;transform:translate(-50%,-50%) scale(1.2);}
  100%{opacity:0;transform:translate(-50%,calc(-50% - 80px)) scale(.8);}
}

/* heart rain */
.heart-rain{
  position:fixed;top:-60px;pointer-events:none;z-index:3;
  animation:fall linear forwards;
}
@keyframes fall{to{transform:translateY(110vh) rotate(360deg);opacity:0;}}
</style>
</head>
<body>

<!-- TOP BANNER -->
<div id="banner">
  <div id="banner-title">👑 ことねちゃんのあそびば 🌸</div>
  <div id="score-pill">⭐ 0</div>
</div>

<!-- ══ MENU SCREEN ══ -->
<div id="screen-menu" class="screen">
  <div class="menu-title">🌸 ことねちゃん、あそぼ！</div>
  <div class="menu-sub">どっちであそぶ？</div>
  <div class="menu-cards">
    <div class="menu-card pink" id="btn-animal">
      <div class="card-emoji">🐱</div>
      <div class="card-label">どうぶつ</div>
    </div>
    <div class="menu-card blue" id="btn-vehicle">
      <div class="card-emoji">🚂</div>
      <div class="card-label">のりもの</div>
    </div>
  </div>
</div>

<!-- ══ ANIMAL SCREEN ══ -->
<div id="screen-animal" class="screen hidden"></div>
<button class="back-btn hidden" id="back-animal">← もどる</button>

<!-- animal boss -->
<div id="animal-boss"></div>
<div id="boss-hp">
  <div id="boss-hp-label">❤️</div>
  <div id="boss-hp-bar-wrap"><div id="boss-hp-bar" style="width:100%"></div></div>
</div>
<div id="boss-event-label">🔥 ボスとうじょう！タップして！</div>

<!-- ══ VEHICLE SCREEN ══ -->
<div id="screen-vehicle" class="screen hidden"></div>
<button class="back-btn hidden" id="back-vehicle">← もどる</button>

<!-- vehicle boss -->
<div id="vehicle-boss"></div>
<div id="vboss-hp">
  <div id="vboss-hp-label">💙</div>
  <div id="vboss-hp-bar-wrap"><div id="vboss-hp-bar" style="width:100%"></div></div>
</div>
<div id="vboss-event-label">🚀 おおきいのりもの！タップして！</div>

<!-- SHARED CANVAS -->
<div id="canvas"></div>

<!-- road (vehicle) -->
<div id="road" class="hidden"></div>

<!-- combo / score -->
<div id="combo-display"></div>

<script>
/* ══════════════════════════════════════
   DATA
══════════════════════════════════════ */
const ANIMALS  = ['🐶','🐱','🐰','🦊','🐻','🐼','🐨','🐯','🦁','🐮','🐷','🐸','🐵','🐔','🐧','🦆','🦉','🦋','🐝','🐞','🐠','🐬','🐳','🐙','🦀','🐢','🦓','🦒','🐘','🦘','🦙','🐕','🐈','🐇','🦩','🌸','🌼','🌻','🍓','🍒','🎀','🎈','🧸'];
const BOSS_ANIMALS = ['🦁','🐯','🐻','🐼','🦊','🐨','🦝'];
const VEHICLES = ['🚗','🚕','🚙','🚌','🚎','🚑','🚒','🚓','🚜','🏎️','🚐','🛻'];
const BOSS_VEHICLES = ['🚂','✈️','🚀','🛸','🚁','🛳️','🚢'];
const RIPPLE_COLORS = ['#ff6eb4','#ff9f43','#ffd93d','#6bcb77','#4d96ff','#a29bfe','#fd79a8'];

/* ══════════════════════════════════════
   STATE
══════════════════════════════════════ */
let score = 0, combo = 0, lastTap = 0;
let currentScreen = 'menu'; // menu | animal | vehicle

// animal boss
let aBossActive = false, aBossHP = 0, aBossMax = 0, aBossTimer = null;
// vehicle boss
let vBossActive = false, vBossHP = 0, vBossMax = 0, vBossTimer = null;
// vehicle lane objects
let vehicles = []; // {el, x, speed, emoji, id}
let vehicleLoop = null;
let vSpawnTimer = null;
let vIdCounter = 0;

/* ══════════════════════════════════════
   ELEMENTS
══════════════════════════════════════ */
const $ = id => document.getElementById(id);
const scorePill     = $('score-pill');
const comboDisplay  = $('combo-display');
const canvas        = $('canvas');

const screenMenu    = $('screen-menu');
const screenAnimal  = $('screen-animal');
const screenVehicle = $('screen-vehicle');
const backAnimal    = $('back-animal');
const backVehicle   = $('back-vehicle');
const road          = $('road');

const animalBoss    = $('animal-boss');
const bossHP        = $('boss-hp');
const bossHPBar     = $('boss-hp-bar');
const bossHPLabel   = $('boss-hp-label');
const bossEventLabel= $('boss-event-label');

const vehicleBoss   = $('vehicle-boss');
const vbossHP       = $('vboss-hp');
const vbossHPBar    = $('vboss-hp-bar');
const vbossEventLabel=$('vboss-event-label');

/* ══════════════════════════════════════
   AUDIO
══════════════════════════════════════ */
let audioCtx = null;
function getCtx(){
  if(!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  return audioCtx;
}
function playNote(freq,dur=.25,type='sine'){
  try{
    const ctx=getCtx();
    const o=ctx.createOscillator(), g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.type=type; o.frequency.setValueAtTime(freq,ctx.currentTime);
    o.frequency.exponentialRampToValueAtTime(freq*1.4,ctx.currentTime+dur*.5);
    g.gain.setValueAtTime(.22,ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+dur);
    o.start();o.stop(ctx.currentTime+dur);
  }catch(e){}
}
const SCALE=[261,294,329,370,415,466,523,587,659,740];
function playTap(c){
  playNote(SCALE[Math.min(c,SCALE.length-1)]);
  if(c>=5) setTimeout(()=>playNote(SCALE[Math.min(c,SCALE.length-1)]*1.5,.18),90);
}
function playBossHit(){playNote(880,.18,'triangle');}
function playBossDead(){
  [523,659,784,1047].forEach((f,i)=>setTimeout(()=>playNote(f,.25),i*80));
}
function playVehicleHit(){playNote(440,.15,'square');}
function playVehicleBossHit(){playNote(660,.18,'sawtooth');}

/* ══════════════════════════════════════
   SCORE / COMBO
══════════════════════════════════════ */
function addScore(pts, x, y){
  score += pts;
  scorePill.textContent = '⭐ ' + score;
  if(pts > 1) showScorePop('+'+pts+'✨', x, y);
}

function showScorePop(text, x, y){
  const el = document.createElement('div');
  el.className = 'score-pop';
  el.textContent = text;
  el.style.cssText = `left:${x}px;top:${y}px;`;
  document.body.appendChild(el);
  setTimeout(()=>el.remove(), 900);
}

function updateCombo(x, y){
  const now = Date.now();
  combo = (now - lastTap < 900) ? combo+1 : 1;
  lastTap = now;
  if(combo >= 3){
    const msgs = {3:'🎉 3コンボ！',4:'🔥 4コンボ！',5:'🌟 すごい！',6:'💖 すごーい！',7:'👑 ことねちゃん最強！'};
    const msg = msgs[combo] || `👑 ${combo}コンボ！！`;
    comboDisplay.textContent = msg;
    comboDisplay.classList.add('visible');
    clearTimeout(comboDisplay._t);
    comboDisplay._t = setTimeout(()=>comboDisplay.classList.remove('visible'),1100);
  }
  playTap(combo-1);
}

/* ══════════════════════════════════════
   FX HELPERS
══════════════════════════════════════ */
function spawnRipple(x,y,color){
  const el=document.createElement('div');
  el.className='ripple';
  const c=color||RIPPLE_COLORS[Math.floor(Math.random()*RIPPLE_COLORS.length)];
  el.style.cssText=`left:${x}px;top:${y}px;width:70px;height:70px;background:${c};opacity:.5;`;
  canvas.appendChild(el);
  setTimeout(()=>el.remove(),800);
}
function spawnStars(x,y,n,icons){
  const def=['⭐','✨','💫','🌟','💖','🌸'];
  const pool=icons||def;
  for(let i=0;i<n;i++){
    const el=document.createElement('div');
    el.className='star-burst';
    el.textContent=pool[Math.floor(Math.random()*pool.length)];
    const a=Math.random()*Math.PI*2,d=70+Math.random()*90;
    el.style.cssText=`left:${x}px;top:${y}px;font-size:${20+Math.random()*14}px;--tx:${Math.cos(a)*d}px;--ty:${Math.sin(a)*d}px;`;
    canvas.appendChild(el);
    setTimeout(()=>el.remove(),1000);
  }
}
function spawnTapAnimal(x,y){
  const el=document.createElement('div');
  el.className='tap-animal';
  el.textContent=ANIMALS[Math.floor(Math.random()*ANIMALS.length)];
  el.style.cssText=`left:${x}px;top:${y}px;font-size:${60+Math.random()*60}px;`;
  canvas.appendChild(el);
  setTimeout(()=>el.remove(),2400);
}
function heartRain(){
  const hearts=['💖','💗','💕','💓','🌸','✨'];
  for(let i=0;i<12;i++){
    setTimeout(()=>{
      const el=document.createElement('div');
      el.className='heart-rain';
      el.textContent=hearts[Math.floor(Math.random()*hearts.length)];
      el.style.cssText=`left:${Math.random()*100}vw;animation-duration:${1.2+Math.random()*1.2}s;font-size:${24+Math.random()*22}px;`;
      document.body.appendChild(el);
      setTimeout(()=>el.remove(),2600);
    },i*80);
  }
}

/* ══════════════════════════════════════
   SCREEN NAVIGATION
══════════════════════════════════════ */
function showScreen(name){
  currentScreen = name;
  screenMenu.classList.toggle('hidden', name!=='menu');
  screenAnimal.classList.toggle('hidden', name!=='animal');
  screenVehicle.classList.toggle('hidden', name!=='vehicle');
  backAnimal.classList.toggle('hidden', name!=='animal');
  backVehicle.classList.toggle('hidden', name!=='vehicle');
  road.classList.toggle('hidden', name!=='vehicle');
  // clean up vehicle objects when leaving
  if(name!=='vehicle') stopVehicleGame();
  if(name==='vehicle') startVehicleGame();
  if(name!=='animal') stopAnimalBoss();
}

$('btn-animal').addEventListener('click', ()=>showScreen('animal'));
$('btn-vehicle').addEventListener('click', ()=>showScreen('vehicle'));
backAnimal.addEventListener('click', ()=>showScreen('menu'));
backVehicle.addEventListener('click', ()=>showScreen('menu'));

/* ══════════════════════════════════════
   ANIMAL GAME  — tap handler
══════════════════════════════════════ */
function handleAnimalTap(x, y){
  spawnRipple(x, y);
  spawnTapAnimal(x, y);
  updateCombo(x, y);
  addScore(1, x, y);
  spawnStars(x,y, combo>=5?8:combo>=3?4:2);
  if(score%20===0) heartRain();

  // trigger boss every 15 points
  if(score>0 && score%15===0 && !aBossActive) startAnimalBoss();
}

/* ══════════════════════════════════════
   ANIMAL BOSS
══════════════════════════════════════ */
function startAnimalBoss(){
  aBossActive = true;
  aBossMax    = 10 + Math.floor(score/20)*5;
  aBossHP     = aBossMax;
  const emoji = BOSS_ANIMALS[Math.floor(Math.random()*BOSS_ANIMALS.length)];
  animalBoss.textContent = emoji;
  animalBoss.classList.add('show');
  bossHPBar.style.width = '100%';
  bossHP.classList.add('show');
  bossEventLabel.classList.add('show');

  // auto-escape after 20 s if not defeated
  aBossTimer = setTimeout(()=>stopAnimalBoss(false), 20000);
}
function stopAnimalBoss(defeated=true){
  clearTimeout(aBossTimer);
  aBossActive = false;
  animalBoss.classList.remove('show');
  bossHP.classList.remove('show');
  bossEventLabel.classList.remove('show');
  if(defeated){
    playBossDead();
    heartRain();
    spawnStars(window.innerWidth/2, window.innerHeight/2, 14, ['⭐','🌟','💫','✨','🎉']);
  }
}
animalBoss.addEventListener('click', e=>{
  e.stopPropagation();
  if(!aBossActive) return;
  aBossHP = Math.max(0, aBossHP-1);
  bossHPBar.style.width = (aBossHP/aBossMax*100)+'%';
  animalBoss.classList.remove('hit');
  void animalBoss.offsetWidth;
  animalBoss.classList.add('hit');
  playBossHit();
  addScore(3, window.innerWidth/2, window.innerHeight/2);
  spawnStars(window.innerWidth/2, window.innerHeight/2, 4, ['⭐','💥','✨']);
  if(aBossHP<=0) stopAnimalBoss(true);
});
animalBoss.addEventListener('touchstart', e=>{
  e.preventDefault(); e.stopPropagation();
  animalBoss.click();
},{passive:false});

/* ══════════════════════════════════════
   VEHICLE GAME
══════════════════════════════════════ */
const LANE_COUNT = 4;
const BANNER_H   = 52;

function laneX(i){
  const w = window.innerWidth;
  return Math.round(w/LANE_COUNT*(i+0.5));
}

function startVehicleGame(){
  vehicles = [];
  vBossActive = false;
  spawnVehicle();
  scheduleVehicleSpawn();
  vehicleLoop = requestAnimationFrame(vehicleFrame);
}
function stopVehicleGame(){
  cancelAnimationFrame(vehicleLoop);
  clearTimeout(vSpawnTimer);
  vehicleLoop = null;
  vehicles.forEach(v=>v.el.remove());
  vehicles = [];
  stopVehicleBoss(false);
}

function scheduleVehicleSpawn(){
  const delay = 1200 + Math.random()*1200;
  vSpawnTimer = setTimeout(()=>{
    if(currentScreen==='vehicle' && !vBossActive){
      spawnVehicle();
      scheduleVehicleSpawn();
    }
  }, delay);
}

function spawnVehicle(){
  const emoji = VEHICLES[Math.floor(Math.random()*VEHICLES.length)];
  const lane  = Math.floor(Math.random()*LANE_COUNT);
  const x     = laneX(lane);
  const speed = 1.2 + Math.random()*1.0;   // px/frame  (slow enough for baby)
  const size  = 52 + Math.floor(Math.random()*20);

  const el = document.createElement('div');
  el.className = 'vehicle';
  el.textContent = emoji;
  el.style.cssText = `left:${x}px;top:${BANNER_H}px;font-size:${size}px;`;
  document.body.appendChild(el);

  const id = ++vIdCounter;
  vehicles.push({el, x, y:BANNER_H, speed, emoji, id, size});

  el.addEventListener('click',   e=>{e.stopPropagation(); hitVehicle(id, e.clientX, e.clientY);});
  el.addEventListener('touchstart', e=>{
    e.preventDefault();e.stopPropagation();
    const t=e.changedTouches[0];
    hitVehicle(id, t.clientX, t.clientY);
  },{passive:false});
}

function vehicleFrame(){
  if(currentScreen!=='vehicle'){vehicleLoop=null;return;}
  const h = window.innerHeight;
  vehicles = vehicles.filter(v=>{
    v.y += v.speed;
    v.el.style.top = v.y + 'px';
    if(v.y > h + 10){ v.el.remove(); return false; }
    return true;
  });
  vehicleLoop = requestAnimationFrame(vehicleFrame);
}

function hitVehicle(id, cx, cy){
  const idx = vehicles.findIndex(v=>v.id===id);
  if(idx===-1) return;
  const v = vehicles[idx];
  v.el.classList.remove('hit-flash');
  void v.el.offsetWidth;
  v.el.classList.add('hit-flash');
  v.el.remove();
  vehicles.splice(idx,1);
  playVehicleHit();
  addScore(2, cx, cy);
  updateCombo(cx, cy);
  spawnRipple(cx, cy, '#4d96ff');
  spawnStars(cx, cy, combo>=5?8:combo>=3?4:2, ['⭐','🌟','💫','🚀']);
  // trigger boss every 10 vehicle hits (tracked via score multiples)
  if(score>0 && score%20===0 && !vBossActive) startVehicleBoss();
}

/* ══════════════════════════════════════
   VEHICLE BOSS
══════════════════════════════════════ */
function startVehicleBoss(){
  clearTimeout(vSpawnTimer);
  vBossActive = true;
  vBossMax    = 12 + Math.floor(score/20)*4;
  vBossHP     = vBossMax;
  const emoji = BOSS_VEHICLES[Math.floor(Math.random()*BOSS_VEHICLES.length)];
  vehicleBoss.textContent = emoji;
  vehicleBoss.style.top   = (BANNER_H + 20) + 'px';
  vehicleBoss.classList.add('show');
  vbossHPBar.style.width  = '100%';
  vbossHP.classList.add('show');
  vbossEventLabel.classList.add('show');

  // slow descent
  let y = BANNER_H + 20;
  const targetY = Math.max(BANNER_H+20, window.innerHeight*0.18);
  const descend = setInterval(()=>{
    if(!vBossActive){clearInterval(descend);return;}
    if(y < targetY){ y+=1; vehicleBoss.style.top=y+'px'; }
    else clearInterval(descend);
  },16);

  vBossTimer = setTimeout(()=>stopVehicleBoss(false), 22000);
}
function stopVehicleBoss(defeated=true){
  clearTimeout(vBossTimer);
  vBossActive = false;
  vehicleBoss.classList.remove('show');
  vbossHP.classList.remove('show');
  vbossEventLabel.classList.remove('show');
  if(defeated){
    playBossDead();
    heartRain();
    spawnStars(window.innerWidth/2, window.innerHeight/2, 16, ['⭐','🌟','💫','✨','🎉','🚀']);
  }
  if(currentScreen==='vehicle') scheduleVehicleSpawn();
}
vehicleBoss.addEventListener('click', e=>{
  e.stopPropagation();
  if(!vBossActive) return;
  vBossHP = Math.max(0, vBossHP-1);
  vbossHPBar.style.width = (vBossHP/vBossMax*100)+'%';
  vehicleBoss.classList.remove('hit');
  void vehicleBoss.offsetWidth;
  vehicleBoss.classList.add('hit');
  playVehicleBossHit();
  addScore(4, window.innerWidth/2, window.innerHeight/2);
  spawnStars(window.innerWidth/2, window.innerHeight/2, 5, ['⭐','💥','✨','🚀']);
  if(vBossHP<=0) stopVehicleBoss(true);
});
vehicleBoss.addEventListener('touchstart', e=>{
  e.preventDefault();e.stopPropagation();
  vehicleBoss.click();
},{passive:false});

/* ══════════════════════════════════════
   MAIN TAP (animal screen)
══════════════════════════════════════ */
function handleTap(x, y){
  if(currentScreen==='animal'){
    if(aBossActive) return; // redirect to boss element
    handleAnimalTap(x, y);
  }
  // vehicle taps handled by vehicle elements directly
}

document.addEventListener('click', e=>{
  if(currentScreen==='menu') return;
  if(e.target.closest('#animal-boss,#vehicle-boss,.vehicle,#back-animal,#back-vehicle,#btn-animal,#btn-vehicle')) return;
  handleTap(e.clientX, e.clientY);
});
document.addEventListener('touchstart', e=>{
  if(currentScreen==='menu') return;
  if(e.target.closest('#animal-boss,#vehicle-boss,.vehicle,#back-animal,#back-vehicle,#btn-animal,#btn-vehicle')) return;
  e.preventDefault();
  [...e.changedTouches].forEach(t=>handleTap(t.clientX, t.clientY));
},{passive:false});
</script>
